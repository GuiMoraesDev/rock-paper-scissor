{
  "name": "rock-paper-scissor",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "turbo start",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "test:e2e:ui": "turbo test:e2e:ui",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check-types": "turbo check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "husky": "^9.1.7",
    "turbo": "^2.4.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "react-hook-form": "^7.72.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  }
}
